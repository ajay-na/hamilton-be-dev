<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Service Invoice</title>
    <style>
      :root {
        --border-color: #333;
        --font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-family);
        font-size: 11px;
        line-height: 1.3;
        color: #000;
        margin: 0;
        padding: 20px;
        background-color: #fff;
      }

      .invoice-container {
        max-width: 800px;
        margin: 0 auto;
      }

      .header-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 15px;
      }

      .header-table td {
        vertical-align: top;
      }

      .company-details {
        border: 1px solid var(--border-color);
        padding: 8px;
        width: 65%;
      }

      .company-name {
        font-weight: bold;
        font-size: 13px;
        margin-bottom: 4px;
      }

      .logo-container {
        border: 1px solid var(--border-color);
        width: 30%;
        text-align: center;
        vertical-align: middle;
        background: #f5f5f5;
      }

      .meta-container {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        gap: 10px;
      }

      .meta-block {
        width: 50%;
        border: 1px solid var(--border-color);
        border-collapse: collapse;
      }

      .meta-block td {
        border: 1px solid #ccc;
        padding: 4px 6px;
        font-size: 10px;
      }

      .meta-block td:first-child {
        font-weight: bold;
        background-color: #fafafa;
        width: 35%;
      }

      .section-title {
        border: 1px solid var(--border-color);
        background-color: #fff;
        text-align: center;
        font-weight: bold;
        font-size: 12px;
        padding: 4px;
        margin-bottom: -1px;
      }

      .data-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid var(--border-color);
        margin-bottom: 15px;
      }

      .data-table th,
      .data-table td {
        border: 1px solid #aaa;
        padding: 5px;
        text-align: left;
        font-size: 10px;
      }

      .data-table th {
        background-color: #fff;
        font-weight: bold;
      }

      .text-right {
        text-align: right;
      }
      .text-center {
        text-align: center;
      }

      /* Grand Summary Design Patterns */
      .summary-wrapper {
        display: flex;
        justify-content: flex-end;
        margin-top: 20px;
      }

      .summary-table {
        width: 40%;
        border-collapse: collapse;
        border: 1px solid var(--border-color);
      }

      .summary-table td {
        padding: 6px 8px;
        font-size: 10px;
        border-bottom: 1px solid #eee;
      }

      .summary-table td:first-child {
        font-weight: bold;
        background-color: #fafafa;
      }

      .grand-total-row td {
        font-size: 12px;
        font-weight: bold;
        background-color: #fff !important;
        border-top: 2px double var(--border-color);
        border-bottom: 1px solid var(--border-color);
      }

      @media print {
        body {
          padding: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="invoice-container">
      <table class="header-table">
        <tr>
          <td class="company-details">
            <div class="company-name">{{company_name}}</div>
            <div>{{addressLine1}}</div>
            <div>{{addressLine2}}</div>
            <div>
              <strong>Phone:</strong> {{company_phone}} |
              <strong>Email:</strong> {{company_email}}
            </div>
          </td>
          <td style="width: 5%"></td>
          <td class="logo-container">
            {{#if company_logo_url}}
            <img
              src="{{company_logo_url}}"
              alt="Logo"
              style="max-height: 60px; padding: 10px"
            />
            {{else}}
            <div style="font-weight: bold; font-size: 14px; padding: 20px 0">
              LOGO
            </div>
            {{/if}}
          </td>
        </tr>
      </table>

      <div class="meta-container">
        <table class="meta-block">
          <tr>
            <td>Service Record ID</td>
            <td>{{service_record_id}}</td>
          </tr>
          <tr>
            <td>Invoice Date</td>
            <td>{{invoice_date}}</td>
          </tr>
          <tr>
            <td>Billed To</td>
            <td>{{firstname}} {{lastname}}</td>
          </tr>
          <tr>
            <td>Mobile No.</td>
            <td>{{mobile_no}}</td>
          </tr>
        </table>

        <table class="meta-block">
          <tr>
            <td>Jobcard Name</td>
            <td>{{jobcard_name}}</td>
          </tr>
          <tr>
            <td>Jobcard Date</td>
            <td>{{jobcard_date}}</td>
          </tr>
          <tr>
            <td>Registration No.</td>
            <td>{{license_plate}}</td>
          </tr>
          <tr>
            <td>Model Name</td>
            <td>{{vehicle_brand_short}} {{vehicle_name}}</td>
          </tr>
        </table>
      </div>
    
      {{#if parts.length}}
      <div class="section-title">Part Invoice</div>
      <table class="data-table">
        <thead>
          <tr>
            <th style="width: 5%">SI.No</th>
            <th style="width: 55%">Part Name</th>
            <th style="width: 10%" class="text-center">Qty</th>
            <th style="width: 15%" class="text-right">Unit price</th>
            <th style="width: 15%" class="text-right">Total price</th>
          </tr>
        </thead>
        <tbody>
          {{#each parts}}
          <tr>
            <td class="text-center">{{addOne @index}}</td>
            <td>{{this.description}}</td>
            <td class="text-center">{{this.qty}}</td>
            <td class="text-right">{{this.unit_price}}</td>
            <td class="text-right">{{this.total_price}}</td>
          </tr>
          {{/each}}
      
          <tr class="total-row" style="font-weight: bold; background-color: #fafafa;">
            <td colspan="4" class="text-right" style="border-top: 1px solid var(--border-color); padding: 6px 8px;">Parts Total:</td>
            <td class="text-right" style="border-top: 1px solid var(--border-color); padding: 6px 8px;">{{parts_total}}</td>
          </tr>
        </tbody>
      </table>
      {{/if}}

      {{#if labour.length}}
      <div class="section-title">Labour Invoice</div>
      <table class="data-table">
        <thead>
          <tr>
            <th style="width: 5%">S.No</th>
            <th style="width: 65%">Labour Work</th>
            <th style="width: 10%" class="text-center">Units</th>
            <th style="width: 20%" class="text-right">Total price</th>
          </tr>
        </thead>
        <tbody>
          {{#each labour}}
          <tr>
            <td class="text-center">{{addOne @index}}</td>
            <td>{{this.description}}</td>
            <td class="text-center">{{this.units}}</td>
            <td class="text-right">{{this.total_price}}</td>
          </tr>
          {{/each}}
      
          <tr class="total-row" style="font-weight: bold; background-color: #fafafa;">
            <td colspan="3" class="text-right" style="border-top: 1px solid var(--border-color); padding: 6px 8px;">Labour Cost Total:</td>
            <td class="text-right" style="border-top: 1px solid var(--border-color); padding: 6px 8px;">{{labour_total}}</td>
          </tr>
        </tbody>
      </table>
      {{/if}}

      <div class="summary-wrapper">
        <table class="summary-table">
          <tr>
            <td>Parts Total</td>
            <td class="text-right">{{#if parts_total}}{{parts_total}}{{else}}0.00{{/if}}</td>
          </tr>
          <tr>
            <td>Labour Total</td>
            <td class="text-right">{{#if labour_total}}{{labour_total}}{{else}}0.00{{/if}}</td>
          </tr>
          <tr class="grand-total-row">
            <td>Grand Total</td>
            <td class="text-right">{{grand_total}}</td>
          </tr>
        </table>
      </div>

    </div>
  </body>
</html>
